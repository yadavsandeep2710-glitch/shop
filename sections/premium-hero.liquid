{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .premium-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_gradient }};
    min-height: {{ section.settings.hero_height }}vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .premium-hero-{{ section.id }} .hero-glass-card {
    padding: 4rem;
    border-radius: 2rem;
    max-width: 60rem;
    z-index: 2;
    margin: 2rem;
  }

  .premium-hero-{{ section.id }} .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .premium-hero-{{ section.id }} .hero-description {
    font-size: 1.8rem;
    line-height: 1.6;
    margin-bottom: 3rem;
    color: rgba(var(--color-foreground), 0.8);
  }

  .premium-hero-{{ section.id }} .hero-blobs {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .premium-hero-{{ section.id }} .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: blob-float 20s infinite alternate cubic-bezier(0.45, 0, 0.55, 1);
  }

  @keyframes blob-float {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(100px, 50px) scale(1.1); }
  }

  .premium-hero-{{ section.id }} .blob-1 {
    width: 400px;
    height: 400px;
    background: #a855f7;
    top: -100px;
    right: -100px;
  }

  .premium-hero-{{ section.id }} .blob-2 {
    width: 300px;
    height: 300px;
    background: #3b82f6;
    bottom: -50px;
    left: -50px;
    animation-delay: -5s;
    animation-duration: 25s;
  }
{%- endstyle -%}

<section class="premium-hero-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>
  
  <div class="page-width">
    <div class="hero-glass-card glass">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="hero-title {{ block.settings.heading_size }}">
              <span class="gradient-text">{{ block.settings.heading | escape }}</span>
            </h2>
          {%- when 'text' -%}
            <div class="hero-description rte" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div class="hero-buttons">
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="button button--large button--premium"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hero Height",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.image-banner.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Future of AI Commerce",
          "label": "t:sections.image-banner.blocks.heading.settings.heading.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.image-banner.blocks.text.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Discover the next generation of digital assets and AI tools powered by AIBrainX.",
          "label": "t:sections.image-banner.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "t:sections.image-banner.blocks.buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Explore Now",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_label_1.label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "t:sections.image-banner.blocks.buttons.settings.button_link_1.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Hero",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "buttons"
        }
      ]
    }
  ]
}
{% endschema %}
